# Database (Neon Postgres)
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Posh webhook & Security
POSH_WEBHOOK_SECRET=
SPONSOR_SESSION_SECRET=
SPONSOR_ACCESS_PASSWORD=
SPONSOR_DECK_PATH=

# Resend (Email Delivery)
RESEND_API_KEY=
CONTACT_WEBHOOK_URL=
BOOKING_WEBHOOK_URL=

# Analytics (PostHog)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Outbound Destinations (Ticket & Waitlist links)
# Overrides server/lib/outbound.ts fallbacks
POSH_TICKET_URL=
LAYLO_URL=
OUTBOUND_TICKETS_FEATURED_URL=
OUTBOUND_TICKETS_US_S3E3_URL=
OUTBOUND_WAITLIST_GENERAL_URL=

# Marketing & Newsletters
LEAD_PROVIDER=mailchimp # mailchimp | beehiiv | convertkit | hubspot | brevo | emailoctopus
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_DC=

# Internal Ops logic
VITE_ENABLE_MONOLITH_OPS=false
VITE_API_TARGET=http://localhost:5001

# Public site-data API tuning
# Raise SITE_DATA_RATE_LIMIT for controlled load tests instead of editing route source.
SITE_DATA_RATE_LIMIT=600
SITE_DATA_RATE_LIMIT_WINDOW_MS=300000
