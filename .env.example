# Database (Neon Postgres)
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Posh webhook security
POSH_WEBHOOK_SECRET=replace-with-posh-secret

# Existing integrations
CONTACT_WEBHOOK_URL=
BOOKING_WEBHOOK_URL=
SPONSOR_ACCESS_PASSWORD=
SPONSOR_SESSION_SECRET=
SPONSOR_DECK_PATH=

# Newsletter provider
LEAD_PROVIDER=mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_DC=

# Optional alternatives
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=

# Internal-only client routes
VITE_ENABLE_MONOLITH_OPS=false
