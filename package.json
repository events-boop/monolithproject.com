{
  "name": "monolith-project",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/sync_hardening_constants.mjs && npm run seo:sync",
    "prebuild": "node scripts/sync_hardening_constants.mjs --rotate && npm run seo:sync",
    "precheck": "node scripts/sync_hardening_constants.mjs && npm run seo:sync",
    "pretest:unit": "node scripts/sync_hardening_constants.mjs && npm run seo:sync",
    "dev": "node scripts/dev.mjs",
    "build": "npm run images:generate && vite build && node --import tsx/esm scripts/prerender_public_routes.mts && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "seo:sync": "node --import tsx/esm scripts/sync_seo_artifacts.mjs",
    "images:generate": "node scripts/generate_responsive_images.mjs",
    "budget:check": "node scripts/check_performance_budget.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e": "npx playwright test --config=playwright.config.ts",
    "test:visual": "VISUAL_TESTS=1 npm run test:e2e",
    "test:visual:update": "VISUAL_TESTS=1 npx playwright test e2e/visual.spec.ts --config=playwright.config.ts --update-snapshots",
    "bundle:report": "npm run build && node scripts/bundle_report.mjs",
    "perf:report": "npm run build && node scripts/bundle_report.mjs && npm run budget:check",
    "pixieset:download": "node scripts/pixieset_bulk_download.mjs",
    "webhooks:replay": "tsx scripts/replay_failed_webhooks.mts",
    "lhci": "lhci autorun",
    "design:lint": "find docs/design -path '*/DESIGN.md' -print0 | xargs -0 -n1 npx @google/design.md lint",
    "design:spec": "npx @google/design.md spec"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "1.0.11",
    "axios": "^1.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cobe": "^0.6.5",
    "compression": "^1.8.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.23.22",
    "helmet": "^8.1.0",
    "input-otp": "^1.4.2",
    "lenis": "^1.3.17",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.1.5",
    "posthog-js": "^1.347.1",
    "react": "^19.2.5",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.5",
    "react-email": "5.2.10",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.64.0",
    "react-photo-album": "^3.5.1",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^2.15.2",
    "resend": "6.10.0",
    "serverless-http": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "wouter": "^3.3.5",
    "yet-another-react-lightbox": "^3.15.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@google/design.md": "^0.1.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.8.1",
    "@types/express": "4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/google.maps": "^3.58.1",
    "@types/helmet": "^0.0.48",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.3",
    "vite": "^7.1.7",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.4",
    "workbox-window": "^7.4.0"
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.2"
}
